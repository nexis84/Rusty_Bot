# EVE SSO credentials — required for /api/token-exchange endpoint
# Get these from https://developers.eveonline.com/
EVE_CLIENT_ID="your_client_id_here"
EVE_CLIENT_SECRET="your_client_secret_here"

# Server port (defaults to 8080)
PORT=8080

# Optional: base URL path prefix (e.g. /rustybot)
# BASE_URL=/rustybot
